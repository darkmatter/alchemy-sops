{
  "name": "alchemy-sops",
  "version": "0.4.2",
  "description": "Alchemy Effect resource for decrypting SOPS files into redacted secret outputs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/darkmatter/alchemy-sops.git"
  },
  "homepage": "https://github.com/darkmatter/alchemy-sops#readme",
  "bugs": {
    "url": "https://github.com/darkmatter/alchemy-sops/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/sops-cli.d.ts",
      "import": "./dist/sops-cli.js",
      "default": "./dist/sops-cli.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.js",
      "default": "./dist/edge.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepack": "bun run build",
    "test": "bun test"
  },
  "dependencies": {
    "@distilled.cloud/cloudflare": "^0.21.3",
    "@effect/platform-bun": ">=4.0.0-beta.84 || >=4.0.0",
    "@effect/platform-node": ">=4.0.0-beta.84 || >=4.0.0",
    "effect": ">=4.0.0-beta.84 || >=4.0.0",
    "sops-age": "^4.0.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "alchemy": "2.0.0-beta.57",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "alchemy": "2.0.0-beta.57",
    "effect": ">=4.0.0-beta.84 || >=4.0.0"
  },
  "peerDependenciesMeta": {
    "alchemy": {
      "optional": false
    },
    "effect": {
      "optional": false
    }
  }
}
